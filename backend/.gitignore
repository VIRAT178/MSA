# Backend Git Ignore

# Environment variables
.env
.env.local
.env.*.local

# Dependencies
node_modules/
package-lock.json
yarn.lock

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Uploads directory (can be large)
uploads/*
!uploads/.gitkeep

# Distribution
dist/
build/

# Optional npm cache directory
.npm

# OS files
.DS_Store
Thumbs.db
